apiVersion: v1
kind: Pod
metadata:
  name: debug-curl
  namespace: devops-challenge
spec:
  restartPolicy: Never

  securityContext:
    runAsNonRoot: true

  containers:
    - name: curl
      image: curlimages/curl:latest

      command: ["sh", "-c", "sleep 3600"]

      securityContext:
        allowPrivilegeEscalation: false
        runAsNonRoot: true
        runAsUser: 1000
        capabilities:
          drop:
            - ALL

      resources:
        requests:
          cpu: 50m
          memory: 64Mi
        limits:
          cpu: 100m
          memory: 128Mi
